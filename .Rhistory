library (maftools)
geneSummary<- getGeneSummary (luad)
head (geneSummary)
png ("Results/Plots/luad_top10_frequently_mutated_genes.png", width = 1200, height = 800)
head (geneSummary)
dev.off ()
png ("Results/Plots/luad_top10_frequently_mutated_genes.png", width = 1200, height = 800)
head (geneSummary)
