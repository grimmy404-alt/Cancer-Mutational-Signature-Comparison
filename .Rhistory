plotmafSummary (luad, rmOutlier = TRUE, addstat = 'median', dashboard = TRUE)
plotmafSummary (luad, rmOutlier = TRUE, addStat = 'median', dashboard = TRUE)
plotmafSummary (luad, addStat = 'median', dashboard = TRUE)
