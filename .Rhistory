png ("Results/Plots/luad_top10_frequently_mutated_genes.png", width = 1200, height = 800, res = 300)
mafBarplot (maf = "Results/CSV_Tables/luad_gene_summary_output.csv", n = 10)
png ("Results/Plots/luad_top10_frequently_mutated_genes.png", width = 1200, height = 800, res = 150)
luad_top10 <- getGeneSummary (luad) [1:10,]
barplot(luad_top10$MutatedSamples, names.arg = luad_top10$Hugo_Symbol, main = "Top 10 Frequently Mutated Genes - LUAD", ylab = "Mutated Samples", col = "tomato", las = 2)
dev.off ()
png ("Results/Plots/coad_top10_frequently_mutated_genes.png", width = 1200, height = 800, res = 150)
coad_top10 <- getGeneSummary (coad) [1:10,]
barplot(coad_top10$MutatedSamples, names.arg = coad_top10$Hugo_Symbol, main = "Top 10 Frequently Mutated Genes - COAD", ylab = "Mutated Samples", col = "tomato", las = 2)
dev.off ()
q()
library (maftools)
mafCompare(m1 = luad, maf = coad, m1Name = "LUAD", m2Name = "COAD")
mafCompare(m1 = luad, m2 = coad, m1Name = "LUAD", m2Name = "COAD")
write.csv (mafCompare(m1 = luad, m2 = coad, m1Name = "LUAD", m2Name = "COAD"), file = "Results/CSV_Tables/luad_vs_coad_comparison.csv", rownames = FALSE)
write.csv (mafCompare(m1 = luad, m2 = coad, m1Name = "LUAD", m2Name = "COAD"), file = "Results/CSV_Tables/luad_vs_coad_comparison.csv", row.names = FALSE)
comparison <- mafCompare(m1 = luad, m2 = coad, m1Name = "LUAD", m2Name = "COAD")
write.csv(comparison$results, file = "Results/CSV_Tables/luad_vs_coad_comparison.csv", row.names = FALSE)
write.csv(comparison$SampleSummary, file = "Results/CSV_Tables/sample_summary.csv", row.names = FALSE)
q()
